{
  "buildCommand": "npm run build:vercel",
  "outputDirectory": "build",
  "installCommand": "npm install",
  "framework": "create-react-app",
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://gcdp2025.vercel.app/api/:path*" },
    { "source": "/uploads/:path*", "destination": "https://gcdp2025.vercel.app/uploads/:path*" },
    { "source": "/StudentPhotos/:path*", "destination": "https://gcdp2025.vercel.app/StudentPhotos/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
